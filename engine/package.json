{
  "name": "@orbytautomation/engine",
  "version": "0.10.0",
  "description": "Orbyt - Automation Engine Framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "clean": "rm -rf dist",
    "tokio-worker:run": "cargo run --quiet --manifest-path ../orbyt-tokio-worker/Cargo.toml",
    "test:yaml-to-orbt": "pnpm run build && node dist/testing/integration/convert-yaml-to-orbt.js",
    "test:distributed": "pnpm run build && node dist/testing/distributed/distributed-smoke.js",
    "test:integration": "pnpm run test:distributed",
    "test": "pnpm run test:integration"
  },
  "keywords": [
    "automation",
    "cron",
    "scheduler",
    "engine",
    "automation-engine",
    "framework",
    "engine-framework"
  ],
  "author": {
    "name": "0xshariq",
    "url": "https://github.com/0xshariq"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xshariq/orbyt.git"
  },
  "bugs": {
    "url": "https://github.com/0xshariq/orbyt/issues"
  },
  "homepage": "https://github.com/0xshariq/orbyt#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@dev-ecosystem/core": "^0.5.4",
    "node-cron": "^4.2.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
